# ========= PaperRAG .env (copy to .env before running) =========

# ----- MySQL -----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=paperrag
# SQLAlchemy URL override (optional; auto-built from above if empty)
MYSQL_URL=

# ----- Qdrant -----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=paperrag
QDRANT_API_KEY=
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ----- Cloud LLM (MiniMax official API) -----
LLM_MODEL=MiniMax-M2.7
LLM_API_BASE=https://api.minimax.chat/v1
LLM_API_KEY=

# ----- Cloud Embedding (Alibaba official API) -----
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=

# ----- Ingest / RAG -----
CHUNK_STRATEGY=v2
CHUNK_SIZE=800
CHUNK_OVERLAP=100
CHUNK_MIN_CHARS=80
CHUNK_NOISE_SYMBOL_RATIO=0.35
CHUNK_DROP_REFERENCES=false
RETRIEVAL_K=8
FINAL_CONTEXT_K=3

# Hybrid retrieval (vector oversample + BM25 fusion)
HYBRID_RETRIEVAL_ENABLED=true
HYBRID_OVERSAMPLE=2.5
HYBRID_ALPHA=0.72
HYBRID_MAX_FETCH=64

# Caches (retrieval TTL + query embedding LRU)
CACHE_RETRIEVAL_ENABLED=true
CACHE_RETRIEVAL_TTL_SEC=180
CACHE_RETRIEVAL_MAX_ENTRIES=256
CACHE_EMBEDDING_ENABLED=true
CACHE_EMBEDDING_MAX_ENTRIES=512

# HTTP retry (embedding API)
HTTP_RETRY_MAX_ATTEMPTS=4
HTTP_RETRY_BACKOFF_BASE_SEC=0.45

# LLM client retries (LangChain / OpenAI-compatible)
LLM_MAX_RETRIES=2

# JSON logs for logger name `app.*`
OBSERVABILITY_JSON_LOGS=true

# ----- Data paths -----
DATA_DIR=./data
PDF_DIR=./data/pdfs
METADATA_JSON=./data/metadata_filtered.json

# ----- API server -----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
