# ========= PaperRAG .env (copy to .env before running) =========

# ----- MySQL -----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=paperrag
# SQLAlchemy URL override (optional; auto-built from above if empty)
MYSQL_URL=

# ----- Chroma -----
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=paperrag

# ----- Ollama (host machine, NOT in docker) -----
# On host: http://localhost:11434
# Inside backend container: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:e4b
EMBEDDING_MODEL=bge-m3

# ----- Ingest / RAG -----
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_K=8
FINAL_CONTEXT_K=3

# ----- Data paths -----
DATA_DIR=./data
PDF_DIR=./data/pdfs
METADATA_JSON=./data/metadata_filtered.json

# ----- API server -----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
